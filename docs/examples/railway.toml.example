# Example Railway config. Not used automatically: copy to the repo root as
# `railway.toml` only if you want to pin these settings instead of relying on
# Railway's dashboard defaults. The root Dockerfile is the actual build
# contract, and Railway will pick it up on its own without this file.
[build]
builder = "DOCKERFILE"

[deploy]
healthcheckPath = "/health"
healthcheckTimeout = 30
restartPolicyType = "ON_FAILURE"
restartPolicyMaxRetries = 3
