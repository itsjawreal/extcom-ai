# --- AI provider (pick one) --------------------------------------------------
# "openrouter" (default) or "openai"
AI_DEFAULT_PROVIDER=openrouter

# Required for the provider you picked. Keys never leave your server.
OPENROUTER_API_KEY=
#OPENAI_API_KEY=

# Model to use. Examples: openrouter/auto, anthropic/claude-haiku-4.5, gpt-5.4-nano
AI_DEFAULT_MODEL=openrouter/auto

# --- Access tokens ------------------------------------------------------------
# Comma-separated token:plan pairs. Make up any long random string as the token
# and paste the same string into the extension popup. Plans: free | pro | power
# (they only differ in rate limits — this is your own API key/bill, not a paid
# tier). Running this just for yourself? Use "power" (60/min, 1000/day) and
# the limit will never realistically get in your way. The tiers exist so that
# if you share your server/key with a few people, one runaway client or a
# heavy user can't burn through your whole API budget unchecked.
AUTH_TOKENS=change-me-to-a-long-random-string:power

# --- Optional -----------------------------------------------------------------
# Enables POST/GET /v1/admin/tokens for issuing tokens stored in SQLite,
# e.g. when sharing your server with friends. Leave empty to keep it disabled.
#ADMIN_SECRET=

# SQLite location (defaults to data/extcom-ai.db; the Docker image sets /data/extcom-ai.db).
#DATABASE_PATH=

# Extra allowed CORS origin besides browser extensions.
#EXTENSION_ORIGIN=

# Sent to OpenRouter as HTTP-Referer for rankings (optional).
#APP_URL=

# Provider base URL overrides (proxies, Azure, local gateways).
#OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#OPENAI_BASE_URL=https://api.openai.com/v1

#PORT=3000
